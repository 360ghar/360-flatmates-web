VITE_API_BASE_URL=https://api.360ghar.com/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_VAPID_PUBLIC_KEY=replace-me

# Development-only OAuth callback host override.
# Production always uses the current browser origin plus /auth/callback so
# flatmates.360ghar.com login cannot be redirected to another 360ghar host.
# Example: VITE_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback
# VITE_AUTH_REDIRECT_URL=
