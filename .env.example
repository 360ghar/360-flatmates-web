VITE_API_BASE_URL=https://api.360ghar.com/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_VAPID_PUBLIC_KEY=replace-me

# ─── Supabase Auth: OAuth Redirect URLs (dashboard config, not env) ───
# Google/Apple OAuth: each origin must be allowlisted or Supabase silently
# falls back to Site URL (https://360ghar.com) — issue #14.
# Supabase → Authentication → URL Configuration
# Site URL: https://360ghar.com  (primary site — do NOT set to flatmates)
# Redirect URLs (prefer wildcards):
#   https://flatmates.360ghar.com/**
#   https://360ghar.com/**
#   https://tours.360ghar.com/**
#   https://admin.360ghar.com/**
#   http://localhost:5173/**
# Client code sends only origin+/auth/callback (no ?next=). Destination is
# stashed in sessionStorage — see src/lib/auth/oauth-redirect.ts.

# Development-only OAuth callback host override.
# Production always uses the current browser origin plus /auth/callback so
# flatmates.360ghar.com login cannot be redirected to another 360ghar host.
# Example: VITE_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback
# VITE_AUTH_REDIRECT_URL=
