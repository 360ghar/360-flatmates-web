VITE_API_BASE_URL=https://api.360ghar.com/api/v1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_VAPID_PUBLIC_KEY=replace-me

# ─── Supabase Auth: OAuth Redirect URLs (dashboard config, not env) ───
# The Google/Apple OAuth redirect requires each deployment's callback URL to be
# added to the Supabase dashboard:
#   Supabase → Authentication → URL Configuration → Redirect URLs
# Add these URLs:
#   https://flatmates.360ghar.com/auth/callback
#   https://360ghar.com/auth/callback
# And set "Site URL" to https://flatmates.360ghar.com
# Without this, OAuth silently redirects to the Site URL (issue #14).

# Development-only OAuth callback host override.
# Production always uses the current browser origin plus /auth/callback so
# flatmates.360ghar.com login cannot be redirected to another 360ghar host.
# Example: VITE_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback
# VITE_AUTH_REDIRECT_URL=
